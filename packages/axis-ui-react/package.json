  "sideEffects": false,
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts src/*/index.tsx --format cjs,esm --dts --external react && node scripts/sync-exports.mjs",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch --external react",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit",
    "sync-exports": "node scripts/sync-exports.mjs",
    "check-exports": "node scripts/sync-exports.mjs --check",
    "prepublishOnly": "node ../../scripts/guard-pnpm-publish.mjs && pnpm build"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "@axis-ds/tokens": "workspace:*",
